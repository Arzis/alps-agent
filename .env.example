# === Application ===
APP_NAME="Enterprise QA Assistant"
APP_VERSION="0.1.0"
ENV="development"
DEBUG=true
API_PREFIX="/api/v1"
HOST="0.0.0.0"
PORT=8000
WORKERS=1

# === DashScope API (阿里云通义千问) ===
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
PRIMARY_LLM_MODEL="qwen-max"
PRIMARY_LLM_TEMPERATURE=0.1
PRIMARY_LLM_MAX_TOKENS=4096
FALLBACK_LLM_MODEL="qwen3-vl-flash"
FALLBACK_LLM_TEMPERATURE=0.0
EMBEDDING_MODEL="text-embedding-v4"
EMBEDDING_DIMENSION=1536

# === PostgreSQL ===
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="user"
POSTGRES_PASSWORD="pass"
POSTGRES_DB="qa_assistant"
POSTGRES_POOL_MIN=5
POSTGRES_POOL_MAX=20

# === Redis ===
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""
REDIS_POOL_MAX=50

# === Milvus ===
MILVUS_HOST="localhost"
MILVUS_PORT=19530
MILVUS_TOKEN=""
MILVUS_DB_NAME="default"
MILVUS_COLLECTION_NAME="knowledge_base"

# === RAG ===
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.7

# === Concurrency ===
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=120

# === Session ===
SESSION_TTL=86400
SHORT_TERM_MEMORY_TTL=86400
MAX_SHORT_TERM_MESSAGES=20

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Upload ===
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.md,.txt
MAX_UPLOAD_SIZE_MB=50
